#include <stdio.h>


int main() {
    char estado1[10], estado2[10];
    char codigo1[10], codigo2[10];   // espaço para códigos
    char nome1[50], nome2[50];       // espaço para nomes
    unsigned long int pop1, pop2;
    float area1, area2;
    float pib1, pib2;
    int pontos1, pontos2;
    float densidade1, densidade2;  // densidade populacional
    float capita1, capita2;        // PIB per capita
    int escolhaJogador;

    printf("--- Cadastro Carta 1 ---\n");
    printf("Estado (AA): ");
    scanf(" %s[^\n]", &estado1);
    
    printf("Código (ex: 01): ");
    scanf(" %s[^\n]", &codigo1);
    
    printf("Nome da Cidade: ");
    scanf(" %[^\n]", &nome1);   // aceita espaços
    printf("População: ");
    scanf("%lu", &pop1);
    printf("Área (km²): ");
    scanf("%f", &area1);
    printf("PIB (bilhões): ");
    scanf("%f", &pib1);
    printf("Pontos Turísticos: ");
    scanf("%d", &pontos1);

    printf("--- Cadastro Carta 2 ---\n");
    printf("Estado (AA): ");
    scanf(" %s[^\n]", &estado2);
    
    printf("Código (ex: 01): ");
    scanf(" %s[^\n]", &codigo2);
    
    printf("Nome da Cidade: ");
    scanf(" %[^\n]", &nome2);   // aceita espaços
    printf("População: ");
    scanf("%lu", &pop2);
    printf("Área (km²): ");
    scanf("%f", &area2);
    printf("PIB (bilhões): ");
    scanf("%f", &pib2);
    printf("Pontos Turísticos: ");
    scanf("%d", &pontos2);

    
    densidade1 = (float)(pop1)/(area1); // densidade populacional = população / pela área
    capita1 = (float)(pib1*1000000000)/pop1; // PIB per capita = PIB / população

    densidade2 = (float)(pop2/area2);
    capita2 = (float)(pib2*1000000000)/pop2;

    printf("\n--- Cartas Cadastradas ---\n");

    printf("Carta 1: %s - %s\n", estado1, codigo1);
    printf("Nome da Cidade: %s\nPopulação: %lu\nÁrea: %.2f km²\nPIB: %.2f bilhões de reais\nPontos turísticos: %d\n",
           nome1, pop1, area1, pib1, pontos1);
    printf("Densidade Populacional: %.2f hab/km²\nPIB per capita: %.2f reais\n", densidade1, capita1);       

    printf("=============================\n");

    printf("Carta 2: %s - %s\n", estado2, codigo2);
    printf("Nome da Cidade: %s\nPopulação: %lu\nÁrea: %.2f km²\nPIB: %.2f bilhões de reais\nPontos turísticos: %d\n",
           nome2, pop2, area2, pib2, pontos2);
    printf("Densidade Populacional: %.2f hab/km²\nPIB per capita: %.2f reais\n", densidade2, capita2);  

    printf("=============================\n");  

    printf ("Jogo SuperTrunfo\n");
    printf ("Escolha um atributo para comparar as duas cartas:\n");
    printf ("1. População\n");
    printf ("2. Área\n");
    printf ("3. PIB\n");
    printf ("4. Pontos Turísticos\n");
    printf ("5. Densidade Populacional\n");
    printf ("6. PIB per capita\n");
    printf ("Escolha: ");
    scanf ("%d", &escolhaJogador);
    
    printf("------Comparaçao das Cartas --------\n");

    switch (escolhaJogador)
    {
    case 1:
       printf("Cidades: %s (%s) e %s (%s)\n", nome1, estado1, nome2, estado2);
       printf("Atributo escolhido: População\n");
       printf ("Valores do atributo:\n");
       printf ("Carta 1 %s - %lu\n", nome1, pop1);
       printf ("Carta 2 %s - %lu\n", nome2, pop2);
       
       break;
    
    case 2:
       printf("Cidades: %s (%s) e %s (%s)\n", nome1, estado1, nome2, estado2);
       printf("Atributo escolhido: Área\n");
       printf ("Valores do atributo:\n");
       printf ("Carta 1 %s - %.2f\n", nome1, area1);
       printf ("Carta 2 %s - %.2f\n", nome2, area2);
        
       break;

    case 3:
       printf("Cidades: %s (%s) e %s (%s)\n", nome1, estado1, nome2, estado2);
       printf("Atributo escolhido: PIB\n");
       printf ("Valores do atributo:\n");
       printf ("Carta 1 %s - %.2f bilhões de reais\n", nome1, pib1);
       printf ("Carta 2 %s - %.2f bilhões de reais\n", nome2, pib2);

       break;

   case 4:
       printf("Cidades: %s (%s) e %s (%s)\n", nome1, estado1, nome2, estado2);
       printf("Atributo escolhido: Pontos turísticos\n");
       printf ("Valores do atributo:\n");
       printf ("Carta 1 %s - %d\n", nome1, pontos1);
       printf ("Carta 2 %s - %.d\n", nome2, pontos2);
       
       break;

    case 5:
       printf("Cidades: %s (%s) e %s (%s)\n", nome1, estado1, nome2, estado2);
       printf("Atributo escolhido: Densidade Populacional\n");
       printf ("Valores do atributo:\n");
       printf ("Carta 1 %s - %.2f hab/km²\n", nome1, densidade1);
       printf ("Carta 2 %s - %.2f hab/km²\n", nome2, densidade2);
       
       break;
       
    case 6:
       printf("Cidades: %s (%s) e %s (%s)\n", nome1, estado1, nome2, estado2);
       printf("Atributo escolhido: PIB per capita\n");
       printf ("Valores do atributo:\n");
       printf ("Carta 1 %s - %.2f reais\n", nome1, capita1);
       printf ("Carta 2 %s - %.2f reais\n", nome2, capita2);

       break;   

    default:
       break;
    }
     
    
    if ((escolhaJogador == 1) && (pop1>pop2)){
       printf("Resultado: Carta 1 (%s) venceu!", nome1);
    } else if ((escolhaJogador == 2) && (area1>area2)){
       printf("Resultado: Carta 1 (%s) venceu!", nome1);
    } else if ((escolhaJogador == 3) && (pib1>pib2)){
       printf("Resultado: Carta 1 (%s) venceu!", nome1);
    } else if ((escolhaJogador == 4) && (pontos1>pontos2)){
       printf("Resultado: Carta 1 (%s) venceu!", nome1);
    } else if ((escolhaJogador == 5) && (densidade2>densidade1)){
       printf("Resultado: Carta 1 (%s) venceu!", nome1);
    } else if ((escolhaJogador == 6) && (capita1>capita2)){
       printf("Resultado: Carta1 (%s) venceu!", nome1);
    } else {
       printf("Resultado: Carta 2 (%s) venceu!", nome2);
    }
    

    return 0;
}
